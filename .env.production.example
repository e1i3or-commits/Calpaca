# Copy to .env beside deploy/compose.example.yml and replace every CHANGE_ME.
# Never commit the resulting .env file.

POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_VALUE
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
BETTER_AUTH_URL=https://calendar.example.com
PUBLIC_URL=https://calendar.example.com

# Google OAuth Web application credentials.
# Authorized redirect URI:
# https://calendar.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Optional email delivery. Port 587 with STARTTLS is widely supported.
#SMTP_URL=smtp://username:password@smtp.example.com:587
#EMAIL_FROM=Calpaca <bookings@example.com>

# Optional provider webhook authentication for delivery/bounce events.
#EMAIL_DELIVERY_WEBHOOK_SECRET=CHANGE_ME

# Public write limits. Defaults are shown.
RATE_LIMIT_HOLDS_PER_MINUTE=20
RATE_LIMIT_BOOKINGS_PER_MINUTE=10
RATE_LIMIT_SUGGESTIONS_PER_MINUTE=5
ACTIVE_HOLDS_PER_EVENT_TYPE=50
