{
  "name": "scheduling-platform",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify": "bash scripts/verify.sh",
    "typecheck": "tsc --noEmit && tsc -p web --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "openapi:generate": "bun run scripts-dev/generate-openapi.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp/index.ts",
    "dev:web": "vite -c web/vite.config.ts",
    "build:web": "vite build -c web/vite.config.ts"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-router": "^1.170.18",
    "better-auth": "^1.6.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "lucide-react": "^1.25.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.1.5"
  }
}
