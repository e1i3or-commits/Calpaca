# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres — the app's only infrastructure dependency.
# Keep DATABASE_URL and TEST_DATABASE_URL pointed at DIFFERENT databases:
# integration tests truncate tables and will wipe app data otherwise.
DATABASE_URL=postgres://test:test@127.0.0.1:5434/app

# Integration tests read this; they SKIP when unset
TEST_DATABASE_URL=postgres://test:test@127.0.0.1:5434/test

# BetterAuth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth client (Web application type).
# Redirect URI must be: ${BETTER_AUTH_URL}/api/auth/callback/google
# Invitee overlay also requires: ${BETTER_AUTH_URL}/api/invitee-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override only when the public auth origin differs from BETTER_AUTH_URL.
INVITEE_CALENDAR_CALLBACK_URL=

# Google sync worker (pg-boss, runs in-process with the server; jobs live in
# the `pgboss` schema of DATABASE_URL).
# PUBLIC_URL: HTTPS origin Google can reach for watch-channel pushes. Leave
# unset in dev — sync then relies on the 15-minute poll sweep.
#PUBLIC_URL=
# DISABLE_JOBS=1 skips starting workers (one-off scripts importing the app).
#DISABLE_JOBS=

# Public write protection (positive integers; defaults shown).
#RATE_LIMIT_HOLDS_PER_MINUTE=20
#RATE_LIMIT_BOOKINGS_PER_MINUTE=10
#RATE_LIMIT_SUGGESTIONS_PER_MINUTE=5
#ACTIVE_HOLDS_PER_EVENT_TYPE=50

# Invite emails (ICS attachments). Both must be set or the mailer is disabled
# and bookings simply never get an invite_sent event — nothing fails.
# SMTP_URL: smtp[s]://user:pass@host:port  (dev capture: smtp://127.0.0.1:2525
# with `bun run scripts-dev/smtp-sink.ts` listening).
# PUBLIC_URL above also controls whether reschedule/cancel links appear in the
# email body — unset means the email ships without links.
#SMTP_URL=
#EMAIL_FROM=Scheduling <bookings@example.com>
